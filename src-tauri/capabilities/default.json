{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Full capability set for the Auto Input application windows",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "opener:default",
    "dialog:default",
    "autostart:default",
    "global-shortcut:default"
  ]
}
